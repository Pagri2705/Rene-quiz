rules_version = '2';

// Firebase Console → Storage → Regeln (Rules) — hier einfügen und veröffentlichen.
// Ablagestruktur: /plans/{uid}/{type}/{dateiname}
service firebase.storage {
  match /b/{bucket}/o {
    match /plans/{uid}/{allPaths=**} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid || request.auth.token.email == 'rene.schneider1410@gmail.com');
      allow write: if request.auth != null &&
        request.auth.token.email == 'rene.schneider1410@gmail.com';
    }
  }
}
